# OCR Provider: "paddleocr" or "mock"
OCR_PROVIDER=mock

# Database URL (SQLite default)
DATABASE_URL=sqlite:///./verifydoc.db

# Upload directory
UPLOAD_DIR=./uploads

# Verification thresholds
NAME_MATCH_THRESHOLD=80
SALARY_RECURRENCE_MIN_MONTHS=3
SALARY_RECURRENCE_LOOKBACK=6
SALARY_STABILITY_TOLERANCE=0.15

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
